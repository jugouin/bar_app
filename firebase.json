{
  "hosting": {
    "public": "public",
    "rewrites": [
      {
        "source": "/pay",
        "destination": "/pay/index.html"
      },
      {
        "source": "/pay/return",
        "destination": "/pay/return/index.html"
      },
      {
        "source": "/pay/back",
        "destination": "/pay/back/index.html"
      },
      {
        "source": "/pay/error",
        "destination": "/pay/error/index.html"
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "cve-bar",
          "appId": "1:705752223630:android:204d8514e588fc608d5edf",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "cve-bar",
          "appId": "1:705752223630:ios:2388fed626fa3bb28d5edf",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "macos": {
        "default": {
          "projectId": "cve-bar",
          "appId": "1:705752223630:ios:2388fed626fa3bb28d5edf",
          "uploadDebugSymbols": false,
          "fileOutput": "macos/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "cve-bar",
          "configurations": {
            "android": "1:705752223630:android:204d8514e588fc608d5edf",
            "ios": "1:705752223630:ios:2388fed626fa3bb28d5edf",
            "macos": "1:705752223630:ios:2388fed626fa3bb28d5edf"
          }
        }
      }
    }
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "emulators": {
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "database": {
      "port": 9000
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true,
      "port": 2000
    },
    "singleProjectMode": true
  }
}
